# Template instance.yaml for the Goobers self-hosting instance.
#
# This file has no secrets in it — `token.env` names an environment variable,
# it does not hold a value — so it's safe to check in and copy verbatim. See
# selfhost/README.md for the full setup walkthrough.
#
# At `goobers init <path>`, the tool writes its own default instance.yaml into
# <path>/instance.yaml. Replace that file's contents with this one (or copy
# this file over it) before running `goobers validate`.
apiVersion: goobers.dev/v1alpha1
kind: Instance
repos:
  - provider: github
    owner: Agent-Clubhouse
    name: Goobers
    # Never an inline token (CFG-009, SEC-010) — set the GOOBERS_GITHUB_TOKEN
    # environment variable before starting the instance. See README.md for
    # the required scopes.
    token:
      env: GOOBERS_GITHUB_TOKEN
# The agentic goobers authenticate the Copilot model backend with a SEPARATE
# token from the org-repo token above: a personal "Copilot Requests"
# fine-grained PAT (that permission is personal-account-only). agent:model is
# sourced from its own env var and injected into the subprocess as
# COPILOT_GITHUB_TOKEN, distinct from GH_TOKEN, so one agentic stage carries
# both at once (issue #287–#289 / multi-token credentials, §3.3). Set
# GOOBERS_COPILOT_TOKEN before starting the instance; never an inline value
# (CFG-009, SEC-010). See docs/guides/github-token-scopes.md.
credentials:
  - capability: agent:model
    token:
      env: GOOBERS_COPILOT_TOKEN
telemetry:
  enabled: true
# Optional instance-level ceilings on top of each workflow's own `readiness`
# block: maxParallelRuns caps total concurrent runs across every workflow in
# this instance; workflowBudgets (a map of workflow name -> runs/hour)
# overrides a named workflow's own maxRunsPerHour. See the three workflow
# definitions under gaggles/goobers/workflows/ for the per-workflow
# maxConcurrentRuns/maxRunsPerHour guardrails these ceilings sit on top of.
runConditions:
  maxParallelRuns: 2
