# Template instance.yaml for the Goobers self-hosting instance.
#
# This file has no secrets in it — `token.env` names an environment variable,
# it does not hold a value — so it's safe to check in and copy verbatim. See
# selfhost/README.md for the full setup walkthrough.
#
# At `goobers init <path>`, the tool writes its own default instance.yaml into
# <path>/instance.yaml. Replace that file's contents with this one (or copy
# this file over it) before running `goobers validate`.
apiVersion: goobers.dev/v1alpha1
kind: Instance
repos:
  - provider: github
    owner: Agent-Clubhouse
    name: Goobers
    # Never an inline token (CFG-009, SEC-010) — set the GOOBERS_GITHUB_TOKEN
    # environment variable before starting the instance. See README.md for
    # the required scopes.
    token:
      env: GOOBERS_GITHUB_TOKEN
# Agentic goobers authenticate the Copilot model backend with a separate
# personal "Copilot Requests" token. Native PR reviews also use a separate
# GitHub identity because GitHub does not allow a PR author to approve its own
# pull request. Set both env vars before starting the instance; never use
# inline values (CFG-009, SEC-010). See docs/guides/github-token-scopes.md.
credentials:
  - capability: agent:model
    token:
      env: GOOBERS_COPILOT_TOKEN
  - capability: github:pr:review
    token:
      env: GOOBERS_GITHUB_REVIEW_TOKEN
telemetry:
  enabled: true
  # Collector push is disabled unless an endpoint is configured here or with
  # GOOBERS_OTLP_ENDPOINT. See docs/guides/jaeger-quickstart.md.
  # otlp:
  #   endpoint: http://127.0.0.1:4317
  #   insecure: true
# Opt in to native notifications for escalated and failed runs. The equivalent
# one-shot daemon override is `goobers up --notify` (`--notify=all` includes
# completed and aborted runs too).
# notifications: true
# Optional instance-level ceilings on top of each workflow's own `readiness`
# block: maxParallelRuns caps total concurrent runs across every workflow in
# this instance; workflowBudgets (a map of workflow name -> runs/hour)
# overrides a named workflow's own maxRunsPerHour. claimsLockTimeout bounds
# cross-process claim-ledger lock acquisition so a wedged holder cannot convoy
# stage dispatch or terminal cleanup. See the three workflow definitions under
# gaggles/goobers/workflows/ for the per-workflow guardrails these ceilings sit
# on top of.
runConditions:
  maxParallelRuns: 2
  claimsLockTimeout: 30s
# Optional runner block. `capabilities` are the toolchains/platform properties
# this runner advertises as preinstalled (RRQ-1); a gaggle/stage requiring one
# the runner does not claim fails to schedule. `envPassthrough` names extra
# ambient env vars carried into every stage and harness subprocess on top of
# the built-in default-deny allowlist (internal/procenv) — the escape hatch for
# a custom toolchain whose env var the built-in list (which already covers the
# Go/.NET/Python/Node/Rust families) does not. It stays default-deny: an
# explicit opt-in list of NAMES, never a value and never os.Environ()
# passthrough; a name whose var is unset is a harmless no-op.
# runner:
#   capabilities: [dotnet@8]
#   envPassthrough: [NUGET_CONFIG_FILE, MSBUILDDISABLENODEREUSE]
