# Clubhouse agent manager
.clubhouse/agents/
.clubhouse/.local/
.clubhouse/agents.json
.clubhouse/settings.local.json

.clubhouse/agents.json.bak

# Go build artifacts
/bin/
# Release artifacts: `go run ./release` writes cross-compiled archives +
# SHA256SUMS here (override with -output). Never commit built binaries.
/dist/
# A bare `go build ./cmd/<name>` (no -o) drops the compiled binary in the CWD,
# so running one from the repo root leaves a stray multi-MB executable named
# after the package. /bin/ does not cover that path, and `git add -A` will
# happily commit it — a 33MB `goobers` binary reached main this way in 6ee0756.
# One entry per root-buildable command package; `make build` writes cmd/* to bin/.
/config-sync
/goober-runtime
/goobers
/operator
/scheduler
/stress
/validate
# The same stray also lands next to the source when `go build .` (or a subagent's
# `go build ./cmd/<name>`) runs from inside the package dir — /goobers above is
# repo-root only and does not match cmd/goobers/goobers (a 37MB binary reached a
# PR this way, #1114). One entry per cmd/ package.
/cmd/config-sync/config-sync
/cmd/goober-runtime/goober-runtime
/cmd/goobers/goobers
/cmd/operator/operator
/cmd/scheduler/scheduler
/cmd/validate/validate
coverage.out
coverage.html
/stress-results/
*.test
*.out

# Portal build artifacts
/portal/node_modules/
/portal/dist/
/portal/coverage/
/portal/*.tsbuildinfo

# Editor / OS cruft
.DS_Store
.idea/
*.swp

# Agent-local (do not commit)
.mcp.json
CLAUDE.md
/config-sync
/operator
/scheduler
/goober-runtime
/validate
