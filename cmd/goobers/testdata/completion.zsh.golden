#compdef goobers

(( $+functions[compdef] )) || {
    autoload -Uz compinit
    compinit
}

_goobers_completion()
{
    local command
    local -a commands flags candidates

    if (( CURRENT == 2 )); then
        commands=(
            'version:print build version, commit, and date (--json for structured output)'
            'versions:print the supported Go toolchain and OS/arch matrix (--json for structured output)'
            'init:scaffold an instance root'
            'scaffold:scaffold a goober or workflow in a gaggle'
            'validate:validate an instance or checked-in config source tree'
            'lint:lint config via the single authoritative validation engine (alias for validate)'
            'config:inspect instance configuration and compare workflow definitions'
            'up:run the daemon (scheduler + runner + loopback HTTP API)'
            'dashboard:serve and open the local operations portal'
            'run:trigger a run manually (still honors run conditions)'
            'signal:fire an external signal to subscribed workflows'
            'workflow:inspect workflows'
            'runs:list runs and report per-run disk usage'
            'status:validate config, show warnings, list runs, or report daemon health'
            'stats:show the instance lifetime summary card'
            'features:list the workflow-DSL features this build supports'
            'reset-rate-limit:clear the hourly run-rate budget without deleting runs/'
            'blocked:inspect and clear the learned blocked-item ledger'
            'claims:inspect and force-release claim leases'
            'trace:show a run'\''s journal events, follow a live run, or show transcripts'
            'escalations:list escalated runs newest first'
            'completion:generate a shell completion script'
            'telemetry:query aggregates or export journaled OTLP windows'
            'journal:the one sanctioned edit to the append-only journal'
            'backlog-query:query/claim one eligible backlog item (a workflow stage)'
            'reconcile-branches:report bounded stale goobers/* branch candidates (a workflow stage)'
            'push-branch:push the worktree'\''s checked-out branch to origin (a workflow stage)'
            'open-pr:open or update the run'\''s PR (a workflow stage)'
            'issue-close-out:comment + close out the claimed issue (a workflow stage)'
            'merge-pr:conjunctive auto-merge via direct-merge or merge-queue (a workflow stage)'
            'record-merge-refusal:record a merge refusal and demote a persistently-stuck lander (a workflow stage)'
            'merge-queue-poll:watch an enqueued PR until merged or evicted (a workflow stage)'
            'reconcile-post-merge:reconcile late merge-queue merges (a workflow stage)'
            'post-merge:post-merge fan-out + close the referenced issue (a workflow stage)'
            'telemetry-query:emit versioned candidate findings (a connector stage)'
            'docs-churn:emit the docs-drift churn digest since the watermark (a connector stage)'
            'pr-select:select one eligible open PR for merge-review (a workflow stage)'
            'gather-sibling-context:load other open PRs as review evidence (a workflow stage)'
            'apply-verdict:publish a merge-review verdict as a native review (a workflow stage)'
            'elect-lander:elect the landing PR among a merge-review cohort (a workflow stage)'
            'update-behind-pr:API-update a clean behind-base PR, else route to remediation (a workflow stage)'
            'gather-pr-context:pr-remediation entrypoint\: select and load a PR'\''s context (a workflow stage)'
            'rebase-pr:rebase-first, finding-driven remediation routing (a workflow stage)'
            'remediation-checkpoint:durable per-PR repass budget + same-diff escalation (a workflow stage)'
            'push-remediated:force-push the remediated branch and clear needs-remediation (a workflow stage)'
            'respond-to-findings:post a validated per-finding remediation response to the claimed PR (a workflow stage)'
            'help'
            '--version:print the version'
            '-h:show help'
            '--help:show help'
        )
        _describe 'command' commands
        return
    fi

    command="${words[2]}"
    flags=(-h --help)
    case "${command}" in
        init)
            flags+=(--demo)
            ;;
        scaffold)
            case "${words[3]:-}" in
                goober) flags+=(--force) ;;
                workflow) flags+=(--force) ;;
            esac
            ;;
        validate)
            flags+=(--check-harness --check-repos --source-tree)
            ;;
        config)
            case "${words[3]:-}" in
                diff) flags+=(--against) ;;
                show) flags+=(--json) ;;
            esac
            ;;
        up)
            flags+=(--quiet --diagnostics --notify --watch-config --cleanup-spans-only-runs)
            ;;
        dashboard)
            flags+=(--port --no-open --dev-assets)
            ;;
        run)
            flags+=(--no-wait)
            ;;
        workflow)
            case "${words[3]:-}" in
                show) flags+=(--dot) ;;
            esac
            ;;
        runs)
            case "${words[3]:-}" in
                list) flags+=(--json --phase --workflow --limit) ;;
                du) flags+=(--json) ;;
            esac
            ;;
        status)
            flags+=(--daemon --json --phase --workflow --limit --watch --interval)
            ;;
        stats)
            flags+=(--since --json)
            ;;
        blocked)
            case "${words[3]:-}" in
                list) flags+=(--json) ;;
            esac
            ;;
        claims)
            case "${words[3]:-}" in
                list) flags+=(--json --stale --gaggle --provider) ;;
                release) flags+=(--gaggle --provider --force) ;;
            esac
            ;;
        trace)
            flags+=(--json --follow --transcripts --transcript)
            ;;
        escalations)
            flags+=(--json)
            ;;
        telemetry)
            case "${words[3]:-}" in
                stats) flags+=(--json --workflow --gaggle --since --until --rebuild) ;;
                errors) flags+=(--json --workflow --gaggle --class --limit --since --until --rebuild) ;;
            esac
            ;;
        journal)
            case "${words[3]:-}" in
                redact) flags+=(--run --path --reason --secret-file) ;;
            esac
            ;;
        backlog-query)
            flags+=(--claim --release)
            ;;
        reconcile-branches)
            flags+=(--delete --max --min-age --after)
            ;;
        telemetry-query)
            flags+=(--window --aggregate --threshold --format)
            ;;
        docs-churn)
            flags+=(--repo --workflow --gaggle --since --buffer-multiplier --format)
            ;;
        gather-sibling-context)
            flags+=(--no-cache --no-verdict-cache)
            ;;
        apply-verdict)
            flags+=(--gate)
            ;;
        elect-lander)
            flags+=(--gate)
            ;;
        remediation-checkpoint)
            flags+=(--budget --escalate)
            ;;
    esac
    if [[ "${PREFIX}" == -* ]]; then
        compadd -a flags
        return
    fi

    case "${command}" in
        scaffold)
            if (( CURRENT == 3 )); then
                candidates=(goober workflow)
                _describe -V 'command' candidates
                return
            fi
            ;;
        config)
            if (( CURRENT == 3 )); then
                candidates=(diff show)
                _describe -V 'command' candidates
                return
            fi
            ;;
        run)
            if (( CURRENT == 3 )); then
                candidates=(abort cancel)
                candidates+=("${(@f)$(command goobers __complete workflows 2>/dev/null)}")
                _describe -V 'workflow' candidates
                return
            elif [[ "${words[3]:-}" == "abort" ]] && (( CURRENT == 4 )); then
                candidates=("${(@f)$(command goobers __complete runs 2>/dev/null)}")
                _describe -V 'run id' candidates
                return
            fi
            ;;
        workflow)
            if (( CURRENT == 3 )); then
                candidates=(show)
                _describe -V 'command' candidates
                return
            elif [[ "${words[3]:-}" == "show" ]] && (( CURRENT == 4 )); then
                candidates=("${(@f)$(command goobers __complete workflows 2>/dev/null)}")
                _describe -V 'workflow' candidates
                return
            fi
            ;;
        runs)
            if (( CURRENT == 3 )); then
                candidates=(list du)
                _describe -V 'command' candidates
                return
            fi
            ;;
        blocked)
            if (( CURRENT == 3 )); then
                candidates=(list clear)
                _describe -V 'command' candidates
                return
            fi
            ;;
        claims)
            if (( CURRENT == 3 )); then
                candidates=(list release)
                _describe -V 'command' candidates
                return
            fi
            ;;
        trace)
            if (( CURRENT == 3 )); then
                candidates=()
                candidates+=("${(@f)$(command goobers __complete runs 2>/dev/null)}")
                _describe -V 'run id' candidates
                return
            fi
            ;;
        escalations)
            if (( CURRENT == 3 )); then
                candidates=(show)
                _describe -V 'command' candidates
                return
            elif [[ "${words[3]:-}" == "show" ]] && (( CURRENT == 4 )); then
                candidates=("${(@f)$(command goobers __complete escalations 2>/dev/null)}")
                _describe -V 'escalated run id' candidates
                return
            fi
            ;;
        completion)
            if (( CURRENT == 3 )); then
                candidates=(bash zsh fish)
                _describe -V 'command' candidates
                return
            fi
            ;;
        telemetry)
            if (( CURRENT == 3 )); then
                candidates=(stats errors export)
                _describe -V 'command' candidates
                return
            fi
            ;;
        journal)
            if (( CURRENT == 3 )); then
                candidates=(redact)
                _describe -V 'command' candidates
                return
            fi
            ;;
    esac

    _directories
}

compdef _goobers_completion goobers
