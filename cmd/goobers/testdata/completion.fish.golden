complete -c goobers -n '__fish_seen_subcommand_from telemetry; and __fish_seen_subcommand_from stats' -l json -d 'Emit JSON'
complete -c goobers -n '__fish_seen_subcommand_from telemetry; and __fish_seen_subcommand_from stats' -l workflow -r -a '(__goobers_completion_workflows)' -d 'Filter by workflow'
