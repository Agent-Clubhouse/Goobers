{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goobers.dev/schemas/workflow.schema.json",
  "title": "Workflow",
  "description": "A process modeled as a deterministic state machine of Tasks and Gates (WF-001..024).",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "goobers.dev/v1alpha1" },
    "kind": { "const": "Workflow" },
    "dslVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gaggle", "triggers", "start"],
      "properties": {
        "gaggle": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string" },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/trigger" },
          "allOf": [
            {
              "if": {
                "contains": {
                  "type": "object",
                  "required": ["type"],
                  "properties": { "type": { "const": "manual" } }
                }
              },
              "then": { "maxItems": 1 }
            }
          ]
        },
        "readiness": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxConcurrentRuns": { "type": "integer", "minimum": 1 },
            "maxRunsPerHour": { "type": "integer", "minimum": 0 },
            "maxRunsPerDay": { "type": "integer", "minimum": 0 },
            "maxChainDepth": { "type": "integer", "minimum": 0 },
            "maxOpenPRs": { "type": "integer", "minimum": 0 }
          }
        },
        "start": { "type": "string", "minLength": 1 },
        "docsRoots": {
          "type": "array",
          "description": "In-repo documentation roots this workflow keeps current (docs-updater, #472/#1016). Ordered repo-relative paths (files or directories); the run's writes are confined to these roots. Each must be non-empty and must not escape the repository.",
          "items": { "type": "string", "minLength": 1 }
        },
        "tasks": { "type": "array", "items": { "$ref": "#/$defs/task" } },
        "gates": { "type": "array", "items": { "$ref": "#/$defs/gate" } }
      }
    }
  },
  "$defs": {
    "metadata": {
      "description": "Deliberately left open (no additionalProperties:false) unlike the rest of this schema: k8s-style metadata objects tolerate forward-compatible extra fields (e.g. a future resourceVersion) by convention (#125).",
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$" },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["manual", "backlog-item", "schedule", "signal", "webhook"],
          "description": "Trigger kind. backlog-item is reserved for V1 and has no V0 runtime consumer; webhook requires GitHub event names in events."
        },
        "selector": {
          "type": "object",
          "description": "Reserved for V1 backlog-item routing; accepted by the V0 schema but not consumed at runtime.",
          "additionalProperties": { "type": "string" }
        },
        "schedule": { "type": "string" },
        "signal": { "type": "string" },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "goal"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["deterministic", "agentic"] },
        "goal": { "type": "string", "minLength": 1 },
        "goober": { "type": "string" },
        "run": {
          "type": "object",
          "additionalProperties": false,
          "required": ["command"],
          "properties": {
            "command": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "env": { "type": "object", "additionalProperties": { "type": "string" } },
            "image": { "type": "string" },
            "network": { "type": "string", "enum": ["none"] },
            "workspace": { "type": "string", "enum": ["repo", "scratch"] },
            "syncBase": { "type": "boolean" }
          },
          "allOf": [
            {
              "not": {
                "properties": {
                  "workspace": { "const": "scratch" },
                  "syncBase": { "const": true }
                },
                "required": ["workspace", "syncBase"]
              }
            }
          ]
        },
        "inputs": { "type": "object", "additionalProperties": { "type": "string" } },
        "inputsFrom": { "type": "object", "additionalProperties": { "type": "string" } },
        "capabilities": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "policyActions": {
          "description": "Closed vocabulary of externally mutating actions this task may perform because policy, persona, or verdict output prescribes them. Agentic tasks must include every unconditional action declared by their referenced goober, and compiler admission requires each action's canonical capability.",
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredCapabilities": {
          "description": "Runner (toolchain/platform) capabilities this stage needs, matched at schedule time against a runner's advertised set (RRQ-1/#1101) — distinct from credential capabilities above.",
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._@=+-]*$" }
        },
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxAttempts"],
          "properties": {
            "maxAttempts": { "type": "integer", "minimum": 1 },
            "backoffSeconds": { "type": "integer", "minimum": 0 }
          }
        },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxDurationSeconds": { "type": "integer", "minimum": 0 },
            "maxTokens": { "type": "integer", "minimum": 0 },
            "maxCostUSD": { "type": "number", "minimum": 0 }
          }
        },
        "expectedOutputs": { "type": "array", "items": { "type": "string" } },
        "continueOnError": { "type": "boolean" },
        "onTimeout": { "type": "string", "enum": ["fail", "salvage"] },
        "next": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "agentic" } } },
          "then": { "required": ["goober"], "not": { "required": ["run"] } }
        },
        {
          "if": { "properties": { "type": { "const": "deterministic" } } },
          "then": { "required": ["run"], "not": { "required": ["goober"] } }
        },
        {
          "if": { "properties": { "onTimeout": { "const": "salvage" } }, "required": ["onTimeout"] },
          "then": { "properties": { "type": { "const": "agentic" } } }
        }
      ]
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "evaluator", "branches"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "evaluator": { "type": "string", "enum": ["automated", "agentic", "human"] },
        "automated": {
          "type": "object",
          "additionalProperties": false,
          "required": ["check"],
          "properties": {
            "check": {
              "type": "string",
              "minLength": 1,
              "description": "Built-in check name: status-equals, output-equals, output-not-equals, output-numeric-gte, output-numeric-lte, output-numeric-lt, output-matches, ci-status, land-outcome, or queue-outcome."
            },
            "params": {
              "type": "object",
              "description": "Check parameters. Output equality checks use key+equals; numeric checks use key+threshold; output-matches uses key+pattern (RE2).",
              "additionalProperties": { "type": "string" }
            },
            "timeoutSeconds": { "type": "integer", "minimum": 1 },
            "retry": {
              "type": "object",
              "additionalProperties": false,
              "required": ["maxAttempts"],
              "properties": {
                "maxAttempts": { "type": "integer", "minimum": 1 },
                "backoffSeconds": { "type": "integer", "minimum": 0 }
              }
            },
            "pollIntervalSeconds": { "type": "integer", "minimum": 1 }
          }
        },
        "agentic": {
          "type": "object",
          "additionalProperties": false,
          "required": ["goober"],
          "properties": {
            "goober": { "type": "string", "minLength": 1 },
            "timeoutSeconds": { "type": "integer", "minimum": 1 },
            "retry": {
              "type": "object",
              "additionalProperties": false,
              "required": ["maxAttempts"],
              "properties": {
                "maxAttempts": { "type": "integer", "minimum": 1 },
                "backoffSeconds": { "type": "integer", "minimum": 0 }
              }
            }
          }
        },
        "human": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "approvers": { "type": "array", "items": { "type": "string" } },
            "timeoutSeconds": { "type": "integer", "minimum": 0 },
            "onTimeout": { "type": "string", "enum": ["remind", "escalate", "reject"] }
          }
        },
        "branches": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "evaluator": { "const": "automated" } } },
          "then": { "required": ["automated"], "not": { "anyOf": [{ "required": ["agentic"] }, { "required": ["human"] }] } }
        },
        {
          "if": { "properties": { "evaluator": { "const": "agentic" } } },
          "then": { "required": ["agentic"], "not": { "anyOf": [{ "required": ["automated"] }, { "required": ["human"] }] } }
        },
        {
          "if": { "properties": { "evaluator": { "const": "human" } } },
          "then": { "required": ["human"], "not": { "anyOf": [{ "required": ["automated"] }, { "required": ["agentic"] }] } }
        }
      ]
    }
  }
}
