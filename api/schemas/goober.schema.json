{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goobers.dev/schemas/goober.schema.json",
  "title": "Goober",
  "description": "A role-specialized AI worker defined as code (GBO-001/GBO-002).",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "goobers.dev/v1alpha1" },
    "kind": { "const": "Goober" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gaggle", "role", "instructions"],
      "properties": {
        "gaggle": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string" },
        "instructions": { "type": "string", "minLength": 1 },
        "harness": { "type": "string", "enum": ["copilot"] },
        "model": {
          "type": "string",
          "enum": [
            "auto",
            "claude-sonnet-5",
            "claude-sonnet-4.6",
            "claude-sonnet-4.5",
            "claude-haiku-4.5",
            "claude-opus-4.8",
            "claude-opus-4.7",
            "claude-opus-4.6",
            "gpt-5.6-sol",
            "gpt-5.6-terra",
            "gpt-5.6-luna",
            "gpt-5.5",
            "gpt-5.4",
            "gpt-5.3-codex",
            "gpt-5.4-mini",
            "gpt-5-mini",
            "gemini-3.1-pro-preview",
            "gemini-3.5-flash",
            "mai-code-1-flash-picker"
          ]
        },
        "harnessOptions": { "type": "object", "additionalProperties": { "type": "string" } },
        "capabilities": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "skills": { "type": "array", "items": { "type": "string" } },
        "tools": { "type": "array", "items": { "type": "string" } },
        "scaleFactor": { "type": "integer", "minimum": 1 },
        "workflows": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "$defs": {
    "metadata": {
      "description": "Deliberately left open (no additionalProperties:false) unlike the rest of this schema: k8s-style metadata objects tolerate forward-compatible extra fields (e.g. a future resourceVersion) by convention (#125).",
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    }
  }
}
