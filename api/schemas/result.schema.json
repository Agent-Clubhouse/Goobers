{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goobers.dev/schemas/result.schema.json",
  "title": "ResultEnvelope",
  "description": "The V0 stage result envelope the runner acts on; consumed by gates and telemetry (ARCHITECTURE.md §5). Bulk outputs are artifact pointers; outputs carries scalars only.",
  "type": "object",
  "additionalProperties": false,
  "required": ["status"],
  "properties": {
    "status": { "type": "string", "enum": ["success", "failure", "blocked"] },
    "outputs": {
      "type": "object",
      "description": "Small declared scalar values only. Anything larger is an artifact, referenced by pointer — state does not travel through outputs.",
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean", "null"]
      }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "artifact-pointer.schema.json" }
    },
    "summary": { "type": "string" },
    "metrics": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "error": { "$ref": "#/$defs/errorInfo" }
  },
  "allOf": [
    {
      "comment": "A failure result must carry error detail.",
      "if": {
        "properties": { "status": { "const": "failure" } },
        "required": ["status"]
      },
      "then": { "required": ["error"] }
    }
  ],
  "$defs": {
    "errorInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "retryable": { "type": "boolean" }
      }
    }
  }
}
