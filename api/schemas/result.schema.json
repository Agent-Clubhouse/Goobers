{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goobers.dev/schemas/result.schema.json",
  "title": "ResultEnvelope",
  "description": "Standard task result the engine acts on; consumed by gates and telemetry (TSK-Q2).",
  "type": "object",
  "additionalProperties": false,
  "required": ["status"],
  "properties": {
    "status": { "type": "string", "enum": ["success", "failed", "needs-escalation"] },
    "outputs": { "type": "object" },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "summary": { "type": "string" },
    "metrics": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "error": { "$ref": "#/$defs/errorInfo" }
  },
  "allOf": [
    {
      "comment": "A non-success result should carry error detail.",
      "if": {
        "properties": { "status": { "const": "failed" } },
        "required": ["status"]
      },
      "then": { "required": ["error"] }
    }
  ],
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "uri"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "minLength": 1 },
        "label": { "type": "string" }
      }
    },
    "errorInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "retryable": { "type": "boolean" }
      }
    }
  }
}
